namespace Tbl;

table EventRaidReward {
  no: int32;
  event_stage_group: int32;
  event_number: int32;
  reward_type: int32;
  goal_amount: int32;
  reward_item_no_1: int32;
  reward_item_amount_1: int32;
  reward_item_no_2: int32;
  reward_item_amount_2: int32;
  reward_item_no_3: int32;
  reward_item_amount_3: int32;
  reward_item_no_4: int32;
  reward_item_amount_4: int32;
}

table EventRaidRewardTable {
