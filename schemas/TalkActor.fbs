namespace Tbl;

table TalkActor {
  no: int32;
  name_sno: int32;
  prefab_path: string;
  portrait512_path: string;
  portrait128_path: string;
  costume_path: string;
  controller_path: string;
  portrait_reverse: int32;
  position_x: float;
  position_y: float;
  position_z: float;
  position_scale: float;
}

table TalkActorTable {
  json: [TalkActor];
}

root_type TalkActorTable;