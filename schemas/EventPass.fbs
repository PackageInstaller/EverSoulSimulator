namespace Tbl;

table EventPass {
  no: int32;
  group: int32;
  event_number: int32;
  point: int32;
  basic_item_no: int32;
  basic_item_amount: int32;
  gold_item_no1: int32;
  gold_item_amount1: int32;
  gold_item_no2: int32;
  gold_item_amount2: int32;
  item_highlight: string;
}

table EventPassTable {
  json: [EventPass];
}

root_type EventPassTable;