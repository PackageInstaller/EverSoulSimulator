namespace Tbl;

table DungeonRelic {
  no: int32;
  group: int32;
  effect_type: int32;
  grade_sno: int32;
  buff_group: int32;
  battlebuff_no: int32;
  relic_type: int32;
  set_no: int32;
  enhance_no: int32;
  effect_buff: int32;
  buff_value1: float;
  buff_value2: float;
  icon_img: string;
  name_sno: int32;
  desc_sno: int32;
  weight: int32;
}

table DungeonRelicTable {
  json: [DungeonRelic];
}

root_type DungeonRelicTable;