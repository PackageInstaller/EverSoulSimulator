namespace Tbl;

table ArenaReward {
  no: int32;
  arena_type: int32;
  rank_from: int32;
  rank_to: int32;
  weekly_item_no: int32;
  weekly_amount: int32;
  weekly_item_no_2: int32;
  weekly_amount_2: int32;
  daily_item_no: int32;
  daily_amount: int32;
  win_item_no: int32;
  win_amount: int32;
  lose_item_no: int32;
  lose_amount: int32;
}

table ArenaRewardTable {
  json: [ArenaReward];
}

root_type ArenaRewardTable;