namespace Tbl;

table EventCalender {
  no: int32;
  name_sno: int32;
  type: int32;
  event_type: int32;
  group: int32;
  contents_limit_no: int32;
  gacha_no: int32;
  hide_calender: int32;
  bar_name: string;
