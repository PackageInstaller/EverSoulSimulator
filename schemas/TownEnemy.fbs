namespace Tbl;

table TownEnemy {
  no: int32;
  prefab_path: string;
  slot: string;
  type: int32;
  movedelay: float;
  movetime: float;
  movespeed: int32;
  avoiddelay: float;
  avoidtime: float;
  avoidspeed: int32;
  atk: int32;
  hp: int32;
  reward: string;
  rewardgroup: int32;
  appear_ratio: int32;
  section: int32;
}

table TownEnemyTable {
  json: [TownEnemy];
}

root_type TownEnemyTable;