  hero_grade: int32;
  signature_no: int32;
  signature_grade: int32;
  signature_level: int32;
  slot_1: int32;
  slot_level_1: int32;
  slot_2: int32;
  slot_level_2: int32;
  slot_3: int32;
  slot_level_3: int32;
  slot_4: int32;
  slot_level_4: int32;
