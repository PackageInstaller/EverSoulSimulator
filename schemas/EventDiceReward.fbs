namespace Tbl;

table EventDiceReward {
  no: int32;
  reward_group: int32;
  reward_type: int32;
  is_repeat: int32;
  reward_value: int32;
  reward_item_no_1: int32;
  reward_item_amount_1: int32;
  reward_item_no_2: int32;
  reward_item_amount_2: int32;
  reward_item_no_3: int32;
  reward_item_amount_3: int32;
}

table EventDiceRewardTable {
  json: [EventDiceReward];
}

root_type EventDiceRewardTable;