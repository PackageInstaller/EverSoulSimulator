namespace Tbl;

table DungeonReward {
  no: int32;
  group_no: int32;
  dungeon_no: int32;
  reward_no_1: int32;
  reward_amount_1: int32;
  reward_no_2: int32;
  reward_amount_2: int32;
  reward_no_3: int32;
  reward_amount_3: int32;
  reward_no_4: int32;
  reward_amount_4: int32;
  floor_reward_no: int32;
  difficulty: int32;
}

table DungeonRewardTable {
  json: [DungeonReward];
}

root_type DungeonRewardTable;