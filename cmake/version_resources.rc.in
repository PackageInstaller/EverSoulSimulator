#include <windows.h>

IDI_APP ICON "@EVERSOUL_ICON_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "EverSoul Simulator Team"
            VALUE "FileDescription", "@EVERSOUL_FILE_DESC@"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "@EVERSOUL_INTERNAL_NAME@"
            VALUE "LegalCopyright", "Original author: Shao Jiang. Windows port: Nekoi."
            VALUE "OriginalFilename", "@EVERSOUL_ORIG_FILENAME@"
            VALUE "ProductName", "EverSoul Offline Simulator"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
